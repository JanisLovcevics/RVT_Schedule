<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Блок текущего урока -->
    <LinearLayout
        android:id="@+id/widget_current_block"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/widget_current_bg"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pašreizējā stunda"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#1565C0"
            android:layout_marginBottom="6dp" />

        <!-- Контейнер для групп (горизонтально) -->
        <LinearLayout
            android:id="@+id/widget_current_groups_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:baselineAligned="false">

            <!-- Группа 1 -->
            <LinearLayout
                android:id="@+id/widget_current_group1_block"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="4dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_current_group1_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. grupa"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/widget_current_lesson_g1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_current_time_g1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#424242"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Группа 2 -->
            <LinearLayout
                android:id="@+id/widget_current_group2_block"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_current_group2_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. grupa"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/widget_current_lesson_g2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_current_time_g2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#424242"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/widget_current_common_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <!-- Без групп (старый формат) -->
        <LinearLayout
            android:id="@+id/widget_current_no_group_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_current_lesson"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nav datu"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:shadowColor="#40000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2" />

            <TextView
                android:id="@+id/widget_current_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#424242"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Блок следующего урока -->
    <LinearLayout
        android:id="@+id/widget_next_block"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/widget_next_bg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nākamā stunda"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#E65100"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/widget_next_day_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#E65100"
            android:gravity="center_horizontal"
            android:layout_marginBottom="6dp"
            android:visibility="gone" />

        <!-- Контейнер для групп (горизонтально) -->
        <LinearLayout
            android:id="@+id/widget_next_groups_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:baselineAligned="false">

            <!-- Группа 1 -->
            <LinearLayout
                android:id="@+id/widget_next_group1_block"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="4dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. grupa"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/widget_next_lesson_g1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_next_time_g1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#424242"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Группа 2 -->
            <LinearLayout
                android:id="@+id/widget_next_group2_block"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. grupa"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/widget_next_lesson_g2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_next_time_g2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#424242"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/widget_next_common_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <!-- Без групп (старый формат) -->
        <LinearLayout
            android:id="@+id/widget_next_no_group_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_next_lesson"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:shadowColor="#40000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2" />

            <TextView
                android:id="@+id/widget_next_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#424242"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>