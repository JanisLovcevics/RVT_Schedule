package com.example.edupageschedule

import java.text.SimpleDateFormat
import java.util.*

// –Ъ–ї–∞—Б—Б –і–ї—П —Е—А–∞–љ–µ–љ–Є—П –Є–љ—Д–Њ—А–Љ–∞—Ж–Є–Є –Њ–± —Г—А–Њ–Ї–∞—Е –і–ї—П –≥—А—Г–њ–њ
internal data class GroupLessonInfo(
        val lessonG1: String = "",
        val timeG1: String = "",
        val lessonG2: String = "",
        val timeG2: String = ""
) {
    fun isEmpty(): Boolean = lessonG1.isEmpty() && lessonG2.isEmpty()
}

// –Э–∞—Е–Њ–і–Є—В —В–µ–Ї—Г—Й–Є–є —Г—А–Њ–Ї –і–ї—П –≥—А—Г–њ–њ —Б —Г—З–µ—В–Њ–Љ –≤—Б–µ—Е –њ—А–∞–≤–Є–ї –Њ—В–Њ–±—А–∞–ґ–µ–љ–Є—П
internal fun findCurrentLessonForGroups(
        group1OnlyLessons: List<Lesson>,
        group2OnlyLessons: List<Lesson>,
        noGroupLessons: List<Lesson>,
        currentDate: String,
        currentTime: Date
): GroupLessonInfo {
    // –Ш—Й–µ–Љ —В–µ–Ї—Г—Й–Є–є —Г—А–Њ–Ї —Б—А–µ–і–Є –Њ–±—Й–Є—Е —Г—А–Њ–Ї–Њ–≤ (–±–µ–Ј –≥—А—Г–њ–њ—Л)
    val (commonLesson, commonTime) = findCurrentLesson(noGroupLessons, currentDate, currentTime)

    if (commonLesson.isNotEmpty()) {
        // –Х—Б—В—М –Њ–±—Й–Є–є —Г—А–Њ–Ї –і–ї—П –≤—Б–µ–≥–Њ –Ї–ї–∞—Б—Б–∞ - –њ–Њ–Ї–∞–Ј—Л–≤–∞–µ–Љ —В–Њ–ї—М–Ї–Њ –µ–≥–Њ
        return GroupLessonInfo(lessonG1 = commonLesson, timeG1 = commonTime)
    }

    // –Ш—Й–µ–Љ —В–µ–Ї—Г—Й–Є–µ —Г—А–Њ–Ї–Є –і–ї—П –Ї–∞–ґ–і–Њ–є –≥—А—Г–њ–њ—Л
    val (lesson1, time1) = findCurrentLesson(group1OnlyLessons, currentDate, currentTime)
    val (lesson2, time2) = findCurrentLesson(group2OnlyLessons, currentDate, currentTime)

    // –Я—А–Њ–≤–µ—А—П–µ–Љ, –µ—Б—В—М –ї–Є —Г—А–Њ–Ї–Є —Г –Њ–±–µ–Є—Е –≥—А—Г–њ–њ
    if (lesson1.isNotEmpty() && lesson2.isNotEmpty()) {
        // –£ –Њ–±–µ–Є—Е –≥—А—Г–њ–њ —А–∞–Ј–љ—Л–µ —Г—А–Њ–Ї–Є - –њ–Њ–Ї–∞–Ј—Л–≤–∞–µ–Љ –Њ–±–∞ —Б –љ–∞–Ј–≤–∞–љ–Є—П–Љ–Є –≥—А—Г–њ–њ
        return GroupLessonInfo(
                lessonG1 = "1. gr: $lesson1",
                timeG1 = time1,
                lessonG2 = "2. gr: $lesson2",
                timeG2 = time2
        )
    } else if (lesson1.isNotEmpty()) {
        // –£—А–Њ–Ї —В–Њ–ї—М–Ї–Њ —Г –њ–µ—А–≤–Њ–є –≥—А—Г–њ–њ—Л
        return GroupLessonInfo(lessonG1 = "1. gr: $lesson1", timeG1 = time1)
    } else if (lesson2.isNotEmpty()) {
        // –£—А–Њ–Ї —В–Њ–ї—М–Ї–Њ —Г –≤—В–Њ—А–Њ–є –≥—А—Г–њ–њ—Л
        return GroupLessonInfo(lessonG1 = "2. gr: $lesson2", timeG1 = time2)
    }

    return GroupLessonInfo()
}

// –Э–∞—Е–Њ–і–Є—В —Б–ї–µ–і—Г—О—Й–Є–є —Г—А–Њ–Ї –і–ї—П –≥—А—Г–њ–њ —Б —Г—З–µ—В–Њ–Љ –≤—Б–µ—Е –њ—А–∞–≤–Є–ї –Њ—В–Њ–±—А–∞–ґ–µ–љ–Є—П
internal fun findNextLessonForGroups(
        group1OnlyLessons: List<Lesson>,
        group2OnlyLessons: List<Lesson>,
        noGroupLessons: List<Lesson>,
        currentDate: String,
        afterTime: Date,
        currentTime: Date
): GroupLessonInfo {
    // –Ш—Й–µ–Љ —Б–ї–µ–і—Г—О—Й–Є–є —Г—А–Њ–Ї —Б—А–µ–і–Є –Њ–±—Й–Є—Е —Г—А–Њ–Ї–Њ–≤ (–±–µ–Ј –≥—А—Г–њ–њ—Л)
    val (commonLesson, commonTime) =
            findNextLessonAfterTime(noGroupLessons, currentDate, afterTime, currentTime)

    if (commonLesson.isNotEmpty()) {
        // –Х—Б—В—М –Њ–±—Й–Є–є —Г—А–Њ–Ї –і–ї—П –≤—Б–µ–≥–Њ –Ї–ї–∞—Б—Б–∞ - –њ–Њ–Ї–∞–Ј—Л–≤–∞–µ–Љ —В–Њ–ї—М–Ї–Њ –µ–≥–Њ
        return GroupLessonInfo(lessonG1 = commonLesson, timeG1 = commonTime)
    }

    // –Ш—Й–µ–Љ —Б–ї–µ–і—Г—О—Й–Є–µ —Г—А–Њ–Ї–Є –і–ї—П –Ї–∞–ґ–і–Њ–є –≥—А—Г–њ–њ—Л
    val (lesson1, time1) =
            findNextLessonAfterTime(group1OnlyLessons, currentDate, afterTime, currentTime)
    val (lesson2, time2) =
            findNextLessonAfterTime(group2OnlyLessons, currentDate, afterTime, currentTime)

    // –Я—А–Њ–≤–µ—А—П–µ–Љ, –µ—Б—В—М –ї–Є —Г—А–Њ–Ї–Є —Г –Њ–±–µ–Є—Е –≥—А—Г–њ–њ
    // ѕровер€ем, есть ли уроки у обеих групп
    if (lesson1.isNotEmpty() && lesson2.isNotEmpty()) {
        // ” обеих групп есть уроки - показываем оба р€дом (слева и справа)
        return GroupLessonInfo(
                lessonG1 = "1. gr: $lesson1",
                timeG1 = time1,
                lessonG2 = "2. gr: $lesson2",
                timeG2 = time2
        )
    } else if (lesson1.isNotEmpty()) {
        // –£—А–Њ–Ї —В–Њ–ї—М–Ї–Њ —Г –њ–µ—А–≤–Њ–є –≥—А—Г–њ–њ—Л
        return GroupLessonInfo(lessonG1 = "1. gr: $lesson1", timeG1 = time1)
    } else if (lesson2.isNotEmpty()) {
        // –£—А–Њ–Ї —В–Њ–ї—М–Ї–Њ —Г –≤—В–Њ—А–Њ–є –≥—А—Г–њ–њ—Л
        return GroupLessonInfo(lessonG1 = "2. gr: $lesson2", timeG1 = time2)
    }

    return GroupLessonInfo()
}

// –Т—Б–њ–Њ–Љ–Њ–≥–∞—В–µ–ї—М–љ–∞—П —Д—Г–љ–Ї—Ж–Є—П –і–ї—П –њ–Њ–ї—Г—З–µ–љ–Є—П –≤—А–µ–Љ–µ–љ–Є –љ–∞—З–∞–ї–∞ —Г—А–Њ–Ї–∞
internal fun getStartTime(timeRange: String?, currentDate: String): Date? {
    if (timeRange == null) return null
    val times = timeRange.split("-")
    if (times.size != 2) return null

    return try {
        val timeStr = times[0].trim()
        val fullDateStr = "$currentDate $timeStr"
        SimpleDateFormat("yyyy-MM-dd HH:mm", Locale.getDefault()).parse(fullDateStr)
    } catch (e: Exception) {
        null
    }
}

// –Э–∞—Е–Њ–і–Є—В —В–µ–Ї—Г—Й–Є–є —Г—А–Њ–Ї –≤ —Б–њ–Є—Б–Ї–µ —Г—А–Њ–Ї–Њ–≤
internal fun findCurrentLesson(
        lessons: List<Lesson>,
        currentDate: String,
        currentTime: Date
): Pair<String, String> {
    // –°–Њ—А—В–Є—А—Г–µ–Љ —Г—А–Њ–Ї–Є –њ–Њ –≤—А–µ–Љ–µ–љ–Є –љ–∞—З–∞–ї–∞ –і–ї—П –њ—А–µ–і—Б–Ї–∞–Ј—Г–µ–Љ–Њ—Б—В–Є
    val sortedLessons =
            lessons.sortedBy { lesson ->
                try {
                    val times = lesson.time.split("-")
                    if (times.size != 2) return@sortedBy Long.MAX_VALUE
                    val timeStr = times[0].trim()
                    val fullDateStr = "$currentDate $timeStr"
                    SimpleDateFormat("yyyy-MM-dd HH:mm", Locale.getDefault())
                            .parse(fullDateStr)
                            ?.time
                            ?: Long.MAX_VALUE
                } catch (e: Exception) {
                    Long.MAX_VALUE
                }
            }

    for (lesson in sortedLessons) {
        val times = lesson.time.split("-")
        if (times.size != 2) continue

        val startTime =
                try {
                    val timeStr = times[0].trim()
                    val fullDateStr = "$currentDate $timeStr"
                    SimpleDateFormat("yyyy-MM-dd HH:mm", Locale.getDefault()).parse(fullDateStr)
                } catch (e: Exception) {
                    continue
                }

        val endTime =
                try {
                    val timeStr = times[1].trim()
                    val fullDateStr = "$currentDate $timeStr"
                    SimpleDateFormat("yyyy-MM-dd HH:mm", Locale.getDefault()).parse(fullDateStr)
                } catch (e: Exception) {
                    continue
                }

        // –£—А–Њ–Ї –Є–і—С—В –њ—А—П–Љ–Њ —Б–µ–є—З–∞—Б
        if (currentTime.after(startTime) && currentTime.before(endTime)) {
            val minutesLeft = ((endTime.time - currentTime.time) / 1000 / 60).toInt()
            return Pair(lesson.subject, "LƒЂdz beigƒБm: $minutesLeft min")
        }
    }
    return Pair("", "")
}

// –Э–∞—Е–Њ–і–Є—В —Б–ї–µ–і—Г—О—Й–Є–є —Г—А–Њ–Ї –њ–Њ—Б–ї–µ —Г–Ї–∞–Ј–∞–љ–љ–Њ–≥–Њ –≤—А–µ–Љ–µ–љ–Є
internal fun findNextLessonAfterTime(
        lessons: List<Lesson>,
        currentDate: String,
        afterTime: Date,
        currentTime: Date
): Pair<String, String> {
    // –°–Њ—А—В–Є—А—Г–µ–Љ —Г—А–Њ–Ї–Є –њ–Њ –≤—А–µ–Љ–µ–љ–Є –љ–∞—З–∞–ї–∞, —З—В–Њ–±—Л –љ–∞–є—В–Є —Б–∞–Љ—Л–є —А–∞–љ–љ–Є–є —Б–ї–µ–і—Г—О—Й–Є–є —Г—А–Њ–Ї
    val sortedLessons =
            lessons.sortedBy { lesson ->
                try {
                    val times = lesson.time.split("-")
                    if (times.size != 2) return@sortedBy Long.MAX_VALUE
                    val timeStr = times[0].trim()
                    val fullDateStr = "$currentDate $timeStr"
                    SimpleDateFormat("yyyy-MM-dd HH:mm", Locale.getDefault())
                            .parse(fullDateStr)
                            ?.time
                            ?: Long.MAX_VALUE
                } catch (e: Exception) {
                    Long.MAX_VALUE
                }
            }

    for (lesson in sortedLessons) {
        val times = lesson.time.split("-")
        if (times.size != 2) continue

        val startTime =
                try {
                    val timeStr = times[0].trim()
                    val fullDateStr = "$currentDate $timeStr"
                    SimpleDateFormat("yyyy-MM-dd HH:mm", Locale.getDefault()).parse(fullDateStr)
                } catch (e: Exception) {
                    continue
                }

        // –Ш—Й–µ–Љ —Г—А–Њ–Ї, –Ї–Њ—В–Њ—А—Л–є –љ–∞—З–Є–љ–∞–µ—В—Б—П –њ–Њ—Б–ї–µ —Г–Ї–∞–Ј–∞–љ–љ–Њ–≥–Њ –≤—А–µ–Љ–µ–љ–Є
        if (startTime.after(afterTime)) {
            val minutesUntil = ((startTime.time - currentTime.time) / 1000 / 60).toInt()

            val timeStr =
                    when {
                        minutesUntil < 1 -> "SƒБkas tagad!"
                        minutesUntil < 60 -> "SƒБkas pƒУc: $minutesUntil min"
                        minutesUntil < 120 -> {
                            val mins = minutesUntil % 60
                            if (mins > 0) "SƒБkas pƒУc: 1 h $mins min" else "SƒБkas pƒУc: 1 h"
                        }
                        else -> {
                            val hours = minutesUntil / 60
                            val mins = minutesUntil % 60
                            if (mins > 0) "SƒБkas pƒУc: $hours h $mins min" else "SƒБkas pƒУc: $hours h"
                        }
                    }

            return Pair(lesson.subject, timeStr)
        }
    }
    return Pair("", "")
}
